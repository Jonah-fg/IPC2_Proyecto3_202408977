@model List<ITGSA__Frontend.Models.EstadoCuentaViewModel>
@{
    ViewData["Title"] = "Estado de Cuenta";
}
<h2>Consultar Estado de Cuenta</h2>

<form method="get" asp-action="EstadoCuenta" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label>NIT (opcional):</label>
            <input name="nit" type="text" class="form-control" placeholder="Ej: 123456-7" />
        </div>
        <div class="col-md-2 align-self-end">
            <button type="submit" class="btn btn-primary">Consultar</button>
        </div>
    </div>
</form>

@if (Model != null && Model.Any())
{
    foreach (var cliente in Model)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h4>Cliente: @cliente.Nit - @cliente.Nombre</h4>
                <h5>Saldo actual: Q. @cliente.SaldoActual.ToString("F2")</h5>
            </div>
            <div class="card-body">
                <h5>Transacciones (más reciente primero)</h5>
                <table class="table table-striped table-bordered">
                    <thead class="thead-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Cargo</th>
                            <th>Abono</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in cliente.Transacciones.OrderByDescending(x => x.Fecha))
                        {
                            <tr>
                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@(t.Cargo > 0 ? "Q. " + t.Cargo.ToString("F2") : "")</td>
                                <td>@(t.Abono > 0 ? "Q. " + t.Abono.ToString("F2") : "")</td>
                                <td>@t.Descripcion</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <p>No se encontraron datos. Asegúrese de haber cargado configuración y transacciones.</p>
}