@model List<ITGSA__Frontend.Models.EstadoCuentaViewModel>
@{
    ViewData["Title"] = "Estado de Cuenta";
}
<h2>Consultar Estado de Cuenta</h2>

<form method="get" asp-action="EstadoCuenta" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label>NIT (opcional):</label>
            <input name="nit" type="text" class="form-control" placeholder="Ej: 123456-7" />
        </div>
        <div class="col-md-2 align-self-end">
            <button type="submit" class="btn btn-primary">Consultar</button>
        </div>
    </div>
</form>

@if (Model != null && Model.Any())
{
    foreach (var cliente in Model)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h4>Cliente: @cliente.Nit - @cliente.Nombre</h4>
                <h5>Saldo actual: Q. @cliente.SaldoActual.ToString("F2")</h5>
            </div>
            <div class="card-body">
                <h5>Transacciones (más reciente primero)</h5>
                <table class="table table-striped table-bordered">
                    <thead class="thead-dark">
                        <tr>
                            <th>Fecha</th>
                            <th>Cargo</th>
                            <th>Abono</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in cliente.Transacciones.OrderByDescending(x => x.Fecha))
                        {
                            <tr>
                                <td>@t.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@(t.Cargo > 0 ? "Q. " + t.Cargo.ToString("F2") : "")</td>
                                <td>@(t.Abono > 0 ? "Q. " + t.Abono.ToString("F2") : "")</td>
                                <td>@t.Descripcion</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <button class="btn btn-danger mt-3" onclick="exportarPDF()">Exportar a PDF</button>
}
else
{
    <p>No se encontraron datos. Asegúrese de haber cargado configuración y transacciones.</p>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        async function exportarPDF() {
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF('p', 'pt', 'a4');
        const elementos = document.querySelectorAll('.card');
            
        for (let i =0; i<elementos.length; i++) {
        const canvas = await html2canvas(elementos[i], { scale: 2 });
        const imgData = canvas.toDataURL('image/png');
        if (i > 0) pdf.addPage();
        pdf.addImage(imgData, 'PNG', 20, 20, 550, 0);
        }
        pdf.save('EstadoCuenta.pdf');
        }
    </script>
}